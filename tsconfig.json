{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "esnext",
    "target": "es2021",
    "sourceMap": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "skipLibCheck": true,
    "strict": true,
    "paths": {
      "@ekzo-dev/*": ["packages/*/src", "packages-adapters/*/src"]
    }
  },
  "include": ["packages/*/src", "packages-adapters/*/src", ".storybook"],
  "exclude": ["dist", "node_modules", "test"],
  "files": ["resource.d.ts"]
}
